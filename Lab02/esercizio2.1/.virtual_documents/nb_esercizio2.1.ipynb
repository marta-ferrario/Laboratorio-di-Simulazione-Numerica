import numpy as np
import matplotlib.pyplot as plt

data = np.loadtxt("data.dat")
data_imp = np.loadtxt("data_imp.dat")

x=data[:,0]
y=data[:,1]-1
y_imp=data_imp[:,1]-1
error=data[:,2]
error_imp=data_imp[:,2]

plt.plot(x,y, ".")
plt.xlabel("Blocchi")
plt.ylabel("I")
plt.errorbar(x,y,yerr=error,)
plt.errorbar(x,y_imp,yerr=error_imp,)
plt.grid(True)
plt.title("Valore medio")

plt.show()



