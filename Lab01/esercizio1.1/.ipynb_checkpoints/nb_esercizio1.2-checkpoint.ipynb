   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "data = np.loadtxt(\"data.dat\")\n",
    "\n",
    "x=data[:,0]\n",
    "y=data[:,1]-(1/12)\n",
    "error=data[:,2]\n",
    "\n",
    "plt.plot(x,y, \".\")\n",
    "plt.xlabel(\"lanci\")\n",
    "plt.ylabel(\"<r> - 1/12\")\n",
    "plt.errorbar(x,y,yerr=error, fmt='o')\n",
    "plt.grid()\n",
    "\n",
    "plt.show()"
   ]
